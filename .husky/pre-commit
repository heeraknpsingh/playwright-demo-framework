#!/usr/bin/env sh

echo ""
echo "╔══════════════════════════════════════════════════════════╗"
echo "║              PRE-COMMIT QUALITY CHECKS                  ║"
echo "╚══════════════════════════════════════════════════════════╝"

# ── Step 1: ESLint + Prettier via lint-staged (staged files only) ────────────
echo ""
echo "  [1/3] Running ESLint + Prettier..."
npx lint-staged
LINT_EXIT=$?
if [ $LINT_EXIT -ne 0 ]; then
  echo ""
  echo "  ✗ ESLint/Prettier failed — fix errors above and re-stage your files"
  echo ""
  exit 1
fi
echo "  ✓ ESLint + Prettier passed"

# ── Step 2: Custom standards checker (staged .ts files only) ────────────────
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' | tr '\n' ' ')

if [ -n "$STAGED_TS" ]; then
  echo ""
  echo "  [2/3] Running coding standards checker..."
  npx ts-node scripts/code-quality/standards-checker.ts $STAGED_TS
  STANDARDS_EXIT=$?
  if [ $STANDARDS_EXIT -ne 0 ]; then
    echo ""
    echo "  ✗ Coding standards failed — fix violations above and re-stage your files"
    echo ""
    exit 1
  fi
else
  echo ""
  echo "  [2/3] No TypeScript files staged — skipping standards check"
fi

# ── Step 3: AI code review (staged diff) ────────────────────────────────────
echo ""
echo "  [3/3] Running AI code review..."
npx ts-node scripts/code-quality/ai-reviewer.ts
AI_EXIT=$?
if [ $AI_EXIT -ne 0 ]; then
  echo ""
  echo "  ✗ AI review failed — fix issues above and re-stage your files"
  echo ""
  exit 1
fi

echo ""
echo "╔══════════════════════════════════════════════════════════╗"
echo "║           ✓  ALL PRE-COMMIT CHECKS PASSED               ║"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""
