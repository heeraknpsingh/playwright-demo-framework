{
  "name": "playwright-demo-framework",
  "version": "1.0.0",
  "description": "Playwright UI + API automation framework for demowebshop.tricentis.com",
  "scripts": {
    "test": "playwright test --grep '@ui | @security | @xss | @session | @a11y'",
    "test:ui": "playwright test --grep @ui",
    "test:api": "playwright test --grep @api",
    "test:security": "playwright test --grep @security",
    "test:xss": "playwright test --grep @xss",
    "test:headed": "playwright test --headed",
    "test:session": "playwright test --grep @session",
    "test:a11y": "playwright test --grep @a11y",
    "test:performance": "playwright test --project=performance",
    "test:smoke": "playwright test --grep @smoke",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report reports/html",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint 'e2e/**/*.ts' 'helpers/**/*.ts' 'page-objects/**/*.ts' 'utils/**/*.ts'",
    "lint:prettier": "prettier --check 'e2e/**/*.ts' 'helpers/**/*.ts' 'page-objects/**/*.ts' 'utils/**/*.ts'",
    "standards:check": "ts-node scripts/code-quality/standards-checker.ts",
    "ai:review": "ts-node scripts/code-quality/ai-reviewer.ts",
    "test:all": "playwright test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-playwright": "^1.6.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "lighthouse": "^9.6.8",
    "winston": "^3.13.0"
  }
}
