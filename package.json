{
  "name": "playwright-demo-framework",
  "version": "1.0.0",
  "description": "Playwright UI + API automation framework for demowebshop.tricentis.com",
  "scripts": {
    "test": "playwright test --grep '@ui | @security | @xss | @session | @a11y'",
    "test:ui": "playwright test --grep @ui",
    "test:api": "playwright test --grep @api",
    "test:security": "playwright test --grep @security",
    "test:xss": "playwright test --grep @xss",
    "test:headed": "playwright test --headed",
    "test:session": "playwright test --grep @session",
    "test:a11y": "playwright test --grep @a11y",
    "test:performance": "playwright test --grep @performance --project=performance",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report reports/html",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "lighthouse": "^9.6.8",
    "winston": "^3.13.0"
  }
}
